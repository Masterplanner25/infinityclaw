# Copy to .env and fill in your values

# Primary Anthropic credential
ANTHROPIC_API_KEY=sk-ant-...

# Optional: gateway auth token (leave blank to disable auth)
CLAW_GATEWAY_TOKEN=

# Optional: Redis URL for distributed queue/events
# REDIS_URL=redis://localhost:6379

# Optional: additional credential profiles (JSON array)
# CLAW_CREDENTIALS=[{"id":"secondary","provider":"anthropic","api_key":"sk-ant-...","model":"claude-haiku-4-5-20251001","priority":10}]
